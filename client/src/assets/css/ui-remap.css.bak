/* ApexCharts tooltip: ensure title/text is visible even when theme flips or CSS order changes. */
.apexcharts-tooltip {
  background: #0f1722 !important;
  border-color: rgba(148, 163, 184, 0.22) !important;
  color: #e2e8f0 !important;
}

.apexcharts-tooltip * {
  color: inherit !important;
}

.apexcharts-tooltip-title {
  background: #16202d !important;
  border-bottom-color: rgba(148, 163, 184, 0.18) !important;
  color: #e2e8f0 !important;
  font-weight: 600 !important;
}

/* If Apex tries to paint series background (green/red), keep tooltip surface consistent. */
.apexcharts-tooltip-series-group {
  background: transparent !important;
}

/* ApexCharts x-axis hover label (was default green). Keep it mint across themes. */
.apexcharts-xaxistooltip,
.apexcharts-xaxistooltip.apexcharts-active {
  background: #2dd4bf !important;
  border-color: #2dd4bf !important;
  color: #0b1220 !important;
}

.apexcharts-xaxistooltip-bottom:before,
.apexcharts-xaxistooltip-bottom:after {
  border-bottom-color: #2dd4bf !important;
}

.apexcharts-xaxistooltip-top:before,
.apexcharts-xaxistooltip-top:after {
  border-top-color: #2dd4bf !important;
}

